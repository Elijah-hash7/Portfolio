---
/* Hero.astro — Backend portfolio hero */
---

<section id="hero" class="hero-root">
  <div class="hero-shell">

    <!-- top bar -->
    <header class="top-bar">
      <span class="top-bar__left mono">Elijah · 2025</span>
      <nav class="top-bar__right mono">
        <a href="/projects">Work</a>
        <a href="#about">About</a>
        <a href="/articles">Article</a> 
      </nav>
    </header>

    <!-- main name block -->
    <div class="hero-name">
      <h1>
        <span class="name-line" data-delay="0">Elijah</span>
        <span class="name-line name-line--indent" data-delay="1">Emmanuel</span>
      </h1>
      <div class="hero-role mono" data-delay="2">
        <span class="role-dot"></span>Backend Engineer
      </div>
    </div>

    <!-- right column -->
    <aside class="hero-aside">
      <div class="hero-stack mono" data-delay="3">
        <span>API</span>
        <span class="sep">/</span>
        <span>Web3</span>
        <span class="sep">/</span>
        <span>Go</span>
        <span class="sep">/</span>
        <span>Git</span>
      </div>

      <p class="hero-bio" data-delay="4">
        Building systems that don't wake you up at 3am.
        APIs, infrastructure, and the boring reliability
        that actually matters.
      </p>

      <a href="/projects" class="hero-cta mono" data-delay="5">
        <span>See my work</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </aside>

    <!-- bottom bar -->
    <footer class="bottom-bar">
      <span class="mono bottom-bar__location">Lagos, NG </span>
      <div class="bottom-bar__line"></div>
      <span class="mono bottom-bar__status">
        <span class="status-dot"></span>Available for work
      </span>
    </footer>
  </div>

  <!-- Loading overlay for Work / Article navigation -->
  <div id="nav-loading" class="nav-loading" aria-hidden="true">
    <div class="nav-loading__bar"></div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('nav-loading');
    const links = document.querySelectorAll('a[href="/projects"], a[href="/articles"]');
    const DURATION = 2200;

    links.forEach((link) => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        if (!href || link.target === '_blank') return;
        e.preventDefault();
        overlay?.classList.add('nav-loading--active');
        overlay?.setAttribute('aria-hidden', 'false');
        setTimeout(() => {
          window.location.href = href;
        }, DURATION);
      });
    });
  });
</script>

<style>
  :root {
    --bg: #080808;
    --text: #efefef;
    --muted: rgba(239, 239, 239, 0.38);
    --accent: #c8f55a;   /* single sharp accent — lime green, techy not flashy */
    --border: rgba(239, 239, 239, 0.08);
    --hero-top-space: clamp(1rem, 2vw, 1.5rem);

    --serif: "Cormorant Garamond", Georgia, serif;
    --mono: "JetBrains Mono", "Courier New", monospace;
  }

  *, *::before, *::after {
    margin: 0; padding: 0; box-sizing: border-box;
  }

  .hero-root {
    position: relative;
    height: 100svh;
    min-height: 720px;
    background: transparent;
    color: var(--text);
    overflow: hidden;
    padding: 0;
  }

  .hero-shell {
    width: 100%;
    min-height: calc(100svh - var(--hero-top-space));
    margin: 0 auto;
    display: grid;
    grid-template-rows: auto 1fr auto;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.9fr);
    grid-template-areas:
      "topbar  topbar"
      "name    aside"
      "botbar  botbar";
    padding: var(--hero-top-space) var(--page-gutter) 0;
    gap: 0;
  }

  /* TOP BAR */
  .top-bar {
    grid-area: topbar;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: clamp(1rem, 2vw, 1.75rem);
    border-bottom: 1px solid var(--border);
    z-index: 1;
    animation: fadeDown 0.6s ease both;
  }

  .top-bar__right {
    display: flex;
    gap: 2rem;
  }

  .top-bar__right a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .top-bar__right a:hover { color: var(--text); }

  /* NAME */
  .hero-name {
    grid-area: name;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: clamp(1.25rem, 2.5vw, 2rem);
    z-index: 1;
  }

  .hero-name h1 {
    font-family: var(--serif);
    font-weight: 700;
    font-size: clamp(3.75rem, 8vw, 7.6rem);
    line-height: 0.88;
    letter-spacing: -0.028em;
    color: var(--text);
  }

  .name-line {
    display: block;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 0.7s ease forwards;
  }

  .name-line[data-delay="0"] { animation-delay: 0.1s; }
  .name-line[data-delay="1"] { animation-delay: 0.22s; }

  /* slight indent on second name line — editorial feel */
  .name-line--indent {
    padding-left: clamp(0.9rem, 2.6vw, 2.5rem);
  }

  .hero-role {
    margin-top: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0;
    animation: fadeUp 0.6s 0.35s ease forwards;
  }

  .role-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  /* ASIDE */
  .hero-aside {
    grid-area: aside;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-end;
    text-align: right;
    padding-left: clamp(1.25rem, 2vw, 2rem);
    padding-bottom: clamp(1.25rem, 2.5vw, 2rem);
    border-left: none;
    z-index: 1;
  }

  .hero-stack {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 1.6rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.4s ease forwards;
  }

  .hero-stack .sep {
    color: var(--border);
    font-size: 0.8rem;
  }

  .hero-bio {
    font-family: var(--mono);
    font-size: clamp(0.76rem, 0.95vw, 0.9rem);
    line-height: 1.7;
    color: rgba(239,239,239,0.6);
    max-width: 300px;
    margin-bottom: 1.7rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.5s ease forwards;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.2rem;
    transition: gap 0.2s ease, opacity 0.2s;
    opacity: 0;
    animation: fadeUp 0.6s 0.6s ease forwards;
  }
  .hero-cta:hover { gap: 1rem; }

  /* BOTTOM BAR */
  .bottom-bar {
    grid-area: botbar;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: clamp(1rem, 2vw, 1.5rem);
    border-top: 1px solid var(--border);
    z-index: 1;
    opacity: 0;
    animation: fadeUp 0.6s 0.7s ease forwards;
  }

  .bottom-bar__line {
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .bottom-bar__status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2.5s ease-in-out infinite;
  }

  /* UTILS */
  .mono { font-family: var(--mono); }

  .top-bar__left {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .bottom-bar__location {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }

  /* ANIMATIONS */
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(-12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.7); }
  }

  /* NAV LOADING */
  .nav-loading {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(5, 7, 12, 0.85);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }
  .nav-loading--active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .nav-loading__bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 3px;
    background: var(--accent);
    width: 0%;
    animation: nav-loading-fill 2.2s ease-out forwards;
  }
  @keyframes nav-loading-fill {
    to { width: 100%; }
  }

  /* MOBILE */
  @media (max-width: 680px) {
    .hero-root {
      min-height: auto;
      height: auto;
      padding-top: 0;
    }

    .hero-shell {
      min-height: auto;
      grid-template-columns: 1fr;
      grid-template-areas:
        "topbar"
        "name"
        "aside"
        "botbar";
      padding-top: 0.9rem;
    }

    .hero-aside {
      align-items: flex-start;
      text-align: left;
      border-left: none;
      border-top: 1px solid var(--border);
      padding-left: 0;
      padding-top: 1.5rem;
    }

    .top-bar {
      padding-bottom: 1rem;
    }

    .hero-name {
      padding-top: 3rem;
    }

    .hero-name h1 {
      font-size: clamp(3.25rem, 18vw, 5rem);
    }

    .hero-bio { max-width: 100%; }
  }
</style>
